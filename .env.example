# Neural Lattice Cognitive Architecture - Configuration
# Copy to .env and adjust as needed

# Base directory for zone file storage
NLCA_BASE_DIR=.

# SQLite database path
NLCA_DB_PATH=nlca.db

# API server settings
NLCA_API_HOST=127.0.0.1
NLCA_API_PORT=8000
NLCA_DEBUG=false

# Pomodoro settings (minutes)
NLCA_POMODORO_MIN=25
NLCA_BREAK_MIN=5
NLCA_LONG_BREAK_MIN=15
